<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="AccentColor">#3D8B5E</Color>
    <Color x:Key="AccentLight">#4FA574</Color>

    <!-- Light Mode -->
    <Color x:Key="LightBackground">#F0F4F0</Color>
    <Color x:Key="LightSurface">#FAFCFA</Color>
    <Color x:Key="LightPrimaryText">#1A2E1A</Color>
    <Color x:Key="LightSecondaryText">#6B7C6B</Color>
    <Color x:Key="LightBorder">#D8E8D8</Color>
    <Color x:Key="LightPlaceholder">#9AAA9A</Color>
    <Color x:Key="LightHeader">#E8F4E8</Color>

    <!-- Dark Mode -->
    <Color x:Key="DarkBackground">#000000</Color>
    <Color x:Key="DarkSurface">#111111</Color>
    <Color x:Key="DarkPrimaryText">#FFFFFF</Color>
    <Color x:Key="DarkSecondaryText">#AAAAAA</Color>
    <Color x:Key="DarkBorder">#222222</Color>
    <Color x:Key="DarkPlaceholder">#555555</Color>
    <Color x:Key="DarkHeader">#111111</Color>

</ResourceDictionary>