<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Foodtrackr.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F0F4F0, Dark=#000000}">

    <Grid RowDefinitions="*,Auto">

        <!-- THEME TOGGLE -->
        <Button x:Name="ThemeToggleBtn"
                Text="🌙"
                Clicked="OnThemeToggleClicked"
                BackgroundColor="#3D8B5E"
                TextColor="White"
                CornerRadius="20"
                HeightRequest="40" WidthRequest="40"
                Padding="0"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,50,24,0"/>

        <!-- MAIN CONTENT -->
        <VerticalStackLayout Grid.Row="0"
                             VerticalOptions="Center"
                             Padding="32,0"
                             Spacing="0">

            <!-- LOGO -->
            <VerticalStackLayout Spacing="8" Margin="0,0,0,40">
                <Label FontSize="40" FontAttributes="Bold"
                       HorizontalOptions="Start">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Food" TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"/>
                            <Span Text="trackr" TextColor="#3D8B5E"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label Text="Track nutrition. Improve lives."
                       FontSize="15"
                       TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"/>
            </VerticalStackLayout>

            <!-- EMAIL -->
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#111111}"
                    Margin="0,0,0,12">
                <Entry x:Name="EmailEntry"
                       Placeholder="Email"
                       Keyboard="Email"
                       BackgroundColor="Transparent"
                       TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                       PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                       Margin="16,0"/>
            </Border>

            <!-- PASSWORD -->
            <Border StrokeShape="RoundRectangle 12"
                    Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                    StrokeThickness="1"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#111111}"
                    Margin="0,0,0,24">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Password"
                       IsPassword="True"
                       BackgroundColor="Transparent"
                       TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                       PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                       Margin="16,0"/>
            </Border>

            <!-- ERROR -->
            <Label x:Name="ErrorLabel"
                   IsVisible="False"
                   TextColor="#D9534F"
                   FontSize="13"
                   Margin="0,0,0,12"/>

            <!-- LOGIN BUTTON -->
            <Button Text="Log In"
                    Clicked="OnLoginClicked"
                    BackgroundColor="#3D8B5E"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="14"
                    HeightRequest="52"
                    Margin="0,0,0,24"/>

            <!-- REGISTER LINK -->
            <HorizontalStackLayout HorizontalOptions="Center" Spacing="4">
                <Label Text="Don't have an account?"
                       TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                       FontSize="14" VerticalOptions="Center"/>
                <Label Text="Register"
                       TextColor="#3D8B5E"
                       FontSize="14"
                       FontAttributes="Bold"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRegisterTapped"/>
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </Grid>
</ContentPage>