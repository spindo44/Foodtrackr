<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Foodtrackr.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F0F4F0, Dark=#000000}">

    <ScrollView>
        <VerticalStackLayout Spacing="16" Padding="32" VerticalOptions="Center">

            <!-- THEME TOGGLE TOP RIGHT -->
            <Grid>
                <Button x:Name="ThemeToggleBtn"
                        Text="🌙"
                        Clicked="OnThemeToggleClicked"
                        BackgroundColor="#3D8B5E"
                        TextColor="White"
                        CornerRadius="20"
                        HeightRequest="40"
                        WidthRequest="40"
                        Padding="0"
                        HorizontalOptions="End"/>
            </Grid>

            <!-- LOGO -->
            <HorizontalStackLayout HorizontalOptions="Center" Margin="0,20,0,0">
                <Label Text="Food"
                       TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                       FontSize="52"
                       FontAttributes="Bold"/>
                <Label Text="trackr"
                       TextColor="#3D8B5E"
                       FontSize="52"
                       FontAttributes="Bold"/>
            </HorizontalStackLayout>

            <Label Text="Track nutrition. Improve lives."
                   FontSize="15"
                   TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                   HorizontalOptions="Center"
                   Margin="0,0,0,24"/>

            <!-- EMAIL -->
            <Border StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="{AppThemeBinding Light=#FAFCFA, Dark=#111111}"
                    Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                    Padding="16,4">
                <Entry x:Name="EmailEntry"
                       Placeholder="Email"
                       PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                       TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                       Keyboard="Email"
                       BackgroundColor="Transparent"/>
            </Border>

            <!-- PASSWORD -->
            <Border StrokeThickness="1.5"
                    StrokeShape="RoundRectangle 14"
                    BackgroundColor="{AppThemeBinding Light=#FAFCFA, Dark=#111111}"
                    Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                    Padding="16,4">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Password"
                       PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                       TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                       IsPassword="True"
                       BackgroundColor="Transparent"/>
            </Border>

            <Label x:Name="ErrorLabel"
                   TextColor="#E53935"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

            <!-- LOGIN BUTTON -->
            <Button Text="Log In"
                    Clicked="OnLoginClicked"
                    BackgroundColor="#3D8B5E"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="14"
                    HeightRequest="52"
                    Margin="0,8,0,0"/>

            <!-- DEV BYPASS -->
            <Button Text="DEV: Skip Login"
                    Clicked="OnDevBypassClicked"
                    BackgroundColor="Transparent"
                    TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                    BorderColor="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                    BorderWidth="1.5"
                    CornerRadius="14"
                    HeightRequest="52"/>

            <Grid ColumnDefinitions="*,Auto,*"
                  ColumnSpacing="10"
                  Margin="0,8,0,8">
                <BoxView Grid.Column="0"
                         HeightRequest="1"
                         Color="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                         VerticalOptions="Center"/>
                <Label Grid.Column="1"
                       Text="or"
                       TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                       VerticalOptions="Center"/>
                <BoxView Grid.Column="2"
                         HeightRequest="1"
                         Color="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                         VerticalOptions="Center"/>
            </Grid>

            <Label HorizontalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnRegisterTapped"/>
                </Label.GestureRecognizers>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Don't have an account? "
                              TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"/>
                        <Span Text="Register"
                              TextColor="#3D8B5E"
                              FontAttributes="Bold"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>