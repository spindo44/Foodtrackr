<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Foodtrackr.Views.CreatePatientPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F0F4F0, Dark=#000000}">

    <Grid RowDefinitions="Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="{AppThemeBinding Light=#E8F4E8, Dark=#1A1A1A}"
              Padding="24,50,24,20"
              ColumnDefinitions="Auto,*">
            <Button Grid.Column="0" Text="←"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent" TextColor="#3D8B5E"
                    FontSize="22" Padding="0" WidthRequest="40"/>
            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                <Label Text="New Patient"
                       TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                       FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Enter patient details"
                       TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                       FontSize="13" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- FORM -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="12" Padding="20,16">

                <!-- DEMOGRAPHICS -->
                <Label Text="Demographics" FontSize="13" FontAttributes="Bold"
                       CharacterSpacing="1"
                       TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#666666}"
                       Margin="0,0,0,4"/>

                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}">
                    <Entry x:Name="NameEntry" Placeholder="Full Name"
                           PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                           TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                           BackgroundColor="Transparent" Margin="16,0"/>
                </Border>

                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}">
                    <Entry x:Name="AgeEntry" Placeholder="Age" Keyboard="Numeric"
                           PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                           TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                           BackgroundColor="Transparent" Margin="16,0"/>
                </Border>

                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}">
                    <Picker x:Name="GenderPicker" Title="Select Gender"
                            TitleColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                            TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                            BackgroundColor="Transparent" Margin="16,0">
                        <Picker.Items>
                            <x:String>Male</x:String>
                            <x:String>Female</x:String>
                            <x:String>Other</x:String>
                            <x:String>Prefer not to say</x:String>
                        </Picker.Items>
                    </Picker>
                </Border>

                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}">
                    <Entry x:Name="EthnicityEntry" Placeholder="Ethnicity"
                           PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                           TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                           BackgroundColor="Transparent" Margin="16,0"/>
                </Border>

                <!-- BODY MEASUREMENTS -->
                <Label Text="Body Measurements" FontSize="13" FontAttributes="Bold"
                       CharacterSpacing="1"
                       TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#666666}"
                       Margin="0,8,0,4"/>

                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}"
                        Padding="16,10">
                    <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                        <Label Text="Metric"
                               TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                               VerticalOptions="Center" FontSize="15"/>
                        <Switch x:Name="UnitSwitch" IsToggled="False"
                                OnColor="#3D8B5E"
                                Toggled="OnUnitSwitchToggled"/>
                        <Label Text="Imperial"
                               TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                               VerticalOptions="Center" FontSize="15"/>
                    </HorizontalStackLayout>
                </Border>

                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}">
                    <Entry x:Name="WeightEntry" Placeholder="Weight (kg)" Keyboard="Numeric"
                           PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                           TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                           BackgroundColor="Transparent" Margin="16,0"/>
                </Border>

                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}">
                    <Entry x:Name="HeightEntry" Placeholder="Height (cm)" Keyboard="Numeric"
                           PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                           TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                           BackgroundColor="Transparent" Margin="16,0"/>
                </Border>

                <!-- MEDICAL INFORMATION -->
                <Label Text="Medical Information" FontSize="13" FontAttributes="Bold"
                       CharacterSpacing="1"
                       TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#666666}"
                       Margin="0,8,0,4"/>

                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}"
                        Padding="16,8">
                    <Editor x:Name="MedicalConditionsEditor"
                            Placeholder="Medical conditions (e.g. diabetes, hypertension)"
                            PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                            TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                            BackgroundColor="Transparent"
                            AutoSize="TextChanges" MinimumHeightRequest="80"/>
                </Border>

                <Border StrokeShape="RoundRectangle 12"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#333333}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#1A1A1A}"
                        Padding="16,8">
                    <Editor x:Name="DietaryRestrictionsEditor"
                            Placeholder="Dietary restrictions (e.g. vegetarian, gluten-free)"
                            PlaceholderColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                            TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                            BackgroundColor="Transparent"
                            AutoSize="TextChanges" MinimumHeightRequest="80"/>
                </Border>

                <Label x:Name="ErrorLabel" IsVisible="False"
                       TextColor="#D9534F" FontSize="13"/>

                <Button Text="Save Patient"
                        Clicked="OnSavePatientClicked"
                        BackgroundColor="#3D8B5E" TextColor="White"
                        FontAttributes="Bold" FontSize="16"
                        CornerRadius="14" HeightRequest="52"
                        Margin="0,8,0,30"/>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>