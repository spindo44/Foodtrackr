<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Foodtrackr.Views.ReportPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F0F4F0, Dark=#000000}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="{AppThemeBinding Light=#E8F4E8, Dark=#111111}"
              Padding="24,50,24,20"
              ColumnDefinitions="Auto,*">
            <Button Grid.Column="0" Text="←" Clicked="OnBackClicked"
                    BackgroundColor="Transparent" TextColor="#3D8B5E"
                    FontSize="22" Padding="0" WidthRequest="40"/>
            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                <Label x:Name="PatientNameLabel" Text="Report"
                       TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                       FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Nutritional Summary"
                       TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                       FontSize="13" HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Grid>

        <!-- DATE RANGE SELECTOR -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light=#FAFCFA, Dark=#111111}"
                StrokeShape="RoundRectangle 16"
                Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                StrokeThickness="1" Margin="20,12,20,0" Padding="16,12">
            <VerticalStackLayout Spacing="10">
                <Label Text="DATE RANGE" FontSize="11" FontAttributes="Bold"
                       CharacterSpacing="1"
                       TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#666666}"/>
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                    <Button Grid.Column="0" x:Name="BtnToday" Text="Today"
                            Clicked="OnRangeSelected"
                            BackgroundColor="#3D8B5E" TextColor="White"
                            CornerRadius="10" FontSize="12" HeightRequest="36"/>
                    <Button Grid.Column="1" x:Name="BtnWeek" Text="7 Days"
                            Clicked="OnRangeSelected"
                            BackgroundColor="{AppThemeBinding Light=#E8F4E8, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=#3D8B5E, Dark=#AAAAAA}"
                            CornerRadius="10" FontSize="12" HeightRequest="36"/>
                    <Button Grid.Column="2" x:Name="BtnMonth" Text="30 Days"
                            Clicked="OnRangeSelected"
                            BackgroundColor="{AppThemeBinding Light=#E8F4E8, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=#3D8B5E, Dark=#AAAAAA}"
                            CornerRadius="10" FontSize="12" HeightRequest="36"/>
                    <Button Grid.Column="3" x:Name="BtnCustom" Text="Custom"
                            Clicked="OnRangeSelected"
                            BackgroundColor="{AppThemeBinding Light=#E8F4E8, Dark=#222222}"
                            TextColor="{AppThemeBinding Light=#3D8B5E, Dark=#AAAAAA}"
                            CornerRadius="10" FontSize="12" HeightRequest="36"/>
                </Grid>
                <Label x:Name="DateRangeLabel" FontSize="13"
                       TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>
        </Border>

        <!-- REPORT CONTENT -->
        <ScrollView Grid.Row="2" Margin="20,12,20,20">
            <VerticalStackLayout Spacing="12">

                <!-- AVERAGES CARD -->
                <Border BackgroundColor="{AppThemeBinding Light=#FAFCFA, Dark=#111111}"
                        StrokeShape="RoundRectangle 16"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                        StrokeThickness="1" Padding="16,14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="DAILY AVERAGES" FontSize="11" FontAttributes="Bold"
                               CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#666666}"/>
                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                            <Border Grid.Column="0" StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{AppThemeBinding Light=#F0F8F0, Dark=#1A2A1A}"
                                    StrokeThickness="0" Padding="8,10">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="KCAL" FontSize="10" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                                           HorizontalOptions="Center" CharacterSpacing="1"/>
                                    <Label x:Name="AvgCaloriesLabel" Text="0"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="#3D8B5E" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="1" StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{AppThemeBinding Light=#F0F8F0, Dark=#1A2A1A}"
                                    StrokeThickness="0" Padding="8,10">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="PROTEIN" FontSize="10" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                                           HorizontalOptions="Center" CharacterSpacing="1"/>
                                    <Label x:Name="AvgProteinLabel" Text="0g"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="#3D8B5E" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="2" StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{AppThemeBinding Light=#F0F8F0, Dark=#1A2A1A}"
                                    StrokeThickness="0" Padding="8,10">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="CARBS" FontSize="10" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                                           HorizontalOptions="Center" CharacterSpacing="1"/>
                                    <Label x:Name="AvgCarbsLabel" Text="0g"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="#3D8B5E" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                            <Border Grid.Column="3" StrokeShape="RoundRectangle 10"
                                    BackgroundColor="{AppThemeBinding Light=#F0F8F0, Dark=#1A2A1A}"
                                    StrokeThickness="0" Padding="8,10">
                                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                    <Label Text="FAT" FontSize="10" FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                                           HorizontalOptions="Center" CharacterSpacing="1"/>
                                    <Label x:Name="AvgFatLabel" Text="0g"
                                           FontSize="18" FontAttributes="Bold"
                                           TextColor="#3D8B5E" HorizontalOptions="Center"/>
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- DAILY BREAKDOWN -->
                <Border BackgroundColor="{AppThemeBinding Light=#FAFCFA, Dark=#111111}"
                        StrokeShape="RoundRectangle 16"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                        StrokeThickness="1" Padding="16,14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="DAILY BREAKDOWN" FontSize="11" FontAttributes="Bold"
                               CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#666666}"/>
                        <StackLayout x:Name="DailyBreakdownContainer" Spacing="8"/>
                    </VerticalStackLayout>
                </Border>

                <!-- RDI SUMMARY -->
                <Border BackgroundColor="{AppThemeBinding Light=#FAFCFA, Dark=#111111}"
                        StrokeShape="RoundRectangle 16"
                        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                        StrokeThickness="1" Padding="16,14">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="RDI COMPLIANCE" FontSize="11" FontAttributes="Bold"
                               CharacterSpacing="1"
                               TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#666666}"/>
                        <StackLayout x:Name="RdiContainer" Spacing="8"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>