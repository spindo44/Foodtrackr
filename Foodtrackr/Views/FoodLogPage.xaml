<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Foodtrackr.Models"
             x:Class="Foodtrackr.Views.FoodLogPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F0F4F0, Dark=#000000}">

    <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="{AppThemeBinding Light=#E8F4E8, Dark=#111111}"
              Padding="24,50,24,20"
              ColumnDefinitions="Auto,*,Auto">
            <Button Grid.Column="0" Text="←"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent" TextColor="#3D8B5E"
                    FontSize="22" Padding="0" WidthRequest="40"/>
            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                <Label x:Name="PatientNameLabel" Text="Food Log"
                       TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                       FontSize="20" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Today's Intake"
                       TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                       FontSize="13" HorizontalOptions="Center"/>
            </VerticalStackLayout>
            <Button Grid.Column="2" x:Name="ThemeToggleBtn" Text="🌙"
                    Clicked="OnThemeToggleClicked"
                    BackgroundColor="#3D8B5E" TextColor="White"
                    CornerRadius="20" HeightRequest="40" WidthRequest="40"
                    Padding="0" VerticalOptions="Center"/>
        </Grid>

        <!-- DAILY SUMMARY CARD -->
        <!-- DAILY SUMMARY CARD -->
        <Border Grid.Row="1"
        BackgroundColor="{AppThemeBinding Light=#FAFCFA, Dark=#111111}"
        StrokeShape="RoundRectangle 16"
        Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
        StrokeThickness="1" Margin="20,12,20,0" Padding="16,14">
            <VerticalStackLayout Spacing="10">
                <Label Text="TODAY'S SUMMARY"
               FontSize="11" FontAttributes="Bold" CharacterSpacing="1"
               TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#666666}"/>
                <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="8">
                    <Border Grid.Column="0" StrokeShape="RoundRectangle 10"
        BackgroundColor="{AppThemeBinding Light=#F0F8F0, Dark=#1A2A1A}"
        StrokeThickness="0" Padding="8,10">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="KCAL" FontSize="10" FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
               HorizontalOptions="Center" CharacterSpacing="1"/>
                            <Label x:Name="TotalCaloriesLabel" Text="0"
               FontSize="18" FontAttributes="Bold"
               TextColor="#3D8B5E" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="1" StrokeShape="RoundRectangle 10"
        BackgroundColor="{AppThemeBinding Light=#F0F8F0, Dark=#1A2A1A}"
        StrokeThickness="0" Padding="8,10">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="PROTEIN" FontSize="10" FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
               HorizontalOptions="Center" CharacterSpacing="1"/>
                            <Label x:Name="TotalProteinLabel" Text="0g"
               FontSize="18" FontAttributes="Bold"
               TextColor="#3D8B5E" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="2" StrokeShape="RoundRectangle 10"
        BackgroundColor="{AppThemeBinding Light=#F0F8F0, Dark=#1A2A1A}"
        StrokeThickness="0" Padding="8,10">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="CARBS" FontSize="10" FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
               HorizontalOptions="Center" CharacterSpacing="1"/>
                            <Label x:Name="TotalCarbsLabel" Text="0g"
               FontSize="18" FontAttributes="Bold"
               TextColor="#3D8B5E" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                    <Border Grid.Column="3" StrokeShape="RoundRectangle 10"
        BackgroundColor="{AppThemeBinding Light=#F0F8F0, Dark=#1A2A1A}"
        StrokeThickness="0" Padding="8,10">
                        <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                            <Label Text="FAT" FontSize="10" FontAttributes="Bold"
               TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
               HorizontalOptions="Center" CharacterSpacing="1"/>
                            <Label x:Name="TotalFatLabel" Text="0g"
               FontSize="18" FontAttributes="Bold"
               TextColor="#3D8B5E" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!-- FOOD LOG LIST -->
        <CollectionView Grid.Row="2" x:Name="FoodLogCollection" Margin="20,12">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center"
                                     Spacing="8" Margin="0,40,0,0">
                    <Label Text="🍽️" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="No food logged yet."
                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                           FontSize="18" FontAttributes="Bold" HorizontalOptions="Center"/>
                    <Label Text="Tap the button below to log a meal."
                           TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                           FontSize="14" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:FoodLogEntry">
                    <Border Margin="0,4"
                            BackgroundColor="{AppThemeBinding Light=#FAFCFA, Dark=#111111}"
                            StrokeShape="RoundRectangle 14"
                            Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                            StrokeThickness="1" Padding="16,12">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEntryTapped"
                                                  CommandParameter="{Binding .}"/>
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding FoodName}" FontSize="14"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                                   LineBreakMode="WordWrap" MaxLines="2"/>
                            <Label Grid.Row="0" Grid.Column="1"
                                   FontSize="15" FontAttributes="Bold"
                                   TextColor="#3D8B5E" HorizontalOptions="End"
                                   VerticalOptions="Start">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Calories, StringFormat='{0:0}'}"/>
                                        <Span Text=" kcal"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Grid.Row="1" Grid.Column="0"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding PortionGrams, StringFormat='{0:0}'}"/>
                                        <Span Text="g · "/>
                                        <Span Text="{Binding MealType}"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label Grid.Row="1" Grid.Column="1"
                                   FontSize="12"
                                   TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                                   HorizontalOptions="End">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="P:"/>
                                        <Span Text="{Binding Protein, StringFormat='{0:0.#}'}"/>
                                        <Span Text="g  C:"/>
                                        <Span Text="{Binding Carbs, StringFormat='{0:0.#}'}"/>
                                        <Span Text="g  F:"/>
                                        <Span Text="{Binding Fat, StringFormat='{0:0.#}'}"/>
                                        <Span Text="g"/>
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- LOG FOOD BUTTON -->
        <Button Grid.Row="3" Text="+ Log Food"
                Clicked="OnAddFoodClicked"
                BackgroundColor="#3D8B5E" TextColor="White" FontAttributes="Bold"
                CornerRadius="14" HeightRequest="52" Margin="20,4,20,4"/>

        <!-- VIEW NUTRITION BUTTON -->
        <Button Grid.Row="4" Text="📊 View Nutrition Analysis"
                Clicked="OnViewNutritionClicked"
                BackgroundColor="Transparent" TextColor="#3D8B5E"
                FontSize="14" HeightRequest="40" Margin="20,0,20,24"/>

        <Button Grid.Row="5" Text="📋 View Report"
        Clicked="OnViewReportClicked"
        BackgroundColor="Transparent" TextColor="#3D8B5E"
        FontSize="14" HeightRequest="40" Margin="20,0,20,24"/>

    </Grid>
</ContentPage>