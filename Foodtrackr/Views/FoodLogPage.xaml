<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Foodtrackr.Views.FoodLogPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{AppThemeBinding Light=#F0F4F0, Dark=#000000}">

    <Grid RowDefinitions="Auto,Auto,*,Auto">

        <!-- HEADER -->
        <Grid Grid.Row="0"
              BackgroundColor="{AppThemeBinding Light=#E8F4E8, Dark=#111111}"
              Padding="24,50,24,20"
              ColumnDefinitions="Auto,*,Auto">

            <Button Grid.Column="0"
                    Text="←"
                    Clicked="OnBackClicked"
                    BackgroundColor="Transparent"
                    TextColor="#3D8B5E"
                    FontSize="22"
                    Padding="0"
                    WidthRequest="40"/>

            <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="Center">
                <Label x:Name="PatientNameLabel"
                       Text="Food Log"
                       TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"
                       FontSize="20"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>
                <Label Text="Today's Intake"
                       TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                       FontSize="13"
                       HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <Button Grid.Column="2"
                    x:Name="ThemeToggleBtn"
                    Text="🌙"
                    Clicked="OnThemeToggleClicked"
                    BackgroundColor="#3D8B5E"
                    TextColor="White"
                    CornerRadius="20"
                    HeightRequest="40"
                    WidthRequest="40"
                    Padding="0"
                    VerticalOptions="Center"/>
        </Grid>

        <!-- DAILY SUMMARY CARD -->
        <Border Grid.Row="1"
                BackgroundColor="{AppThemeBinding Light=#FAFCFA, Dark=#111111}"
                StrokeShape="RoundRectangle 16"
                Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                StrokeThickness="1"
                Margin="20,12,20,0"
                Padding="20,16">
            <Grid ColumnDefinitions="*,*,*,*">
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                    <Label Text="Calories"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                           HorizontalOptions="Center"/>
                    <Label x:Name="TotalCaloriesLabel"
                           Text="0"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#3D8B5E"
                           HorizontalOptions="Center"/>
                    <Label Text="kcal"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                    <Label Text="Protein"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                           HorizontalOptions="Center"/>
                    <Label x:Name="TotalProteinLabel"
                           Text="0g"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#3D8B5E"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                    <Label Text="Carbs"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                           HorizontalOptions="Center"/>
                    <Label x:Name="TotalCarbsLabel"
                           Text="0g"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#3D8B5E"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="4">
                    <Label Text="Fat"
                           FontSize="11"
                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                           HorizontalOptions="Center"/>
                    <Label x:Name="TotalFatLabel"
                           Text="0g"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#3D8B5E"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- FOOD LOG LIST -->
        <CollectionView Grid.Row="2"
                        x:Name="FoodLogCollection"
                        Margin="20,12">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8"
                                     Margin="0,40,0,0">
                    <Label Text="🍽️"
                           FontSize="48"
                           HorizontalOptions="Center"/>
                    <Label Text="No food logged yet."
                           TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"/>
                    <Label Text="Tap the button below to log a meal."
                           TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                           FontSize="14"
                           HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,5"
                            BackgroundColor="{AppThemeBinding Light=#FAFCFA, Dark=#111111}"
                            StrokeShape="RoundRectangle 16"
                            Stroke="{AppThemeBinding Light=#D8E8D8, Dark=#222222}"
                            StrokeThickness="1"
                            Padding="20,14">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding FoodName}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{AppThemeBinding Light=#1A2E1A, Dark=#FFFFFF}"/>
                                <Label FontSize="13"
                                       TextColor="{AppThemeBinding Light=#6B7C6B, Dark=#AAAAAA}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding PortionGrams}"/>
                                            <Span Text="g  ·  "/>
                                            <Span Text="{Binding MealType}"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1"
                                                 HorizontalOptions="End"
                                                 VerticalOptions="Center"
                                                 Spacing="2">
                                <Label FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#3D8B5E"
                                       HorizontalOptions="End">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Calories}"/>
                                            <Span Text=" kcal"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label FontSize="12"
                                       TextColor="{AppThemeBinding Light=#9AAA9A, Dark=#555555}"
                                       HorizontalOptions="End">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="P:"/>
                                            <Span Text="{Binding Protein}"/>
                                            <Span Text="g"/>
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- ADD FOOD BUTTON -->
        <Button Grid.Row="3"
                Text="+ Log Food"
                Clicked="OnLogFoodClicked"
                BackgroundColor="#3D8B5E"
                TextColor="White"
                FontAttributes="Bold"
                CornerRadius="14"
                HeightRequest="52"
                Margin="20,10,20,30"/>

    </Grid>
</ContentPage>