<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Foodtrackr.Views.RegisterPage"
             Shell.NavBarIsVisible="False"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#121212}">

    <ScrollView>
        <VerticalStackLayout Spacing="15" Padding="30" VerticalOptions="Center">

            <Label Text="Create Account"
                   FontSize="32"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F5F5F5}"
                   Margin="0,40,0,0"/>

            <Label Text="Join Foodtrackr today"
                   FontSize="16"
                   HorizontalOptions="Center"
                   TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"
                   Margin="0,0,0,20"/>

            <Border StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    BackgroundColor="White"
                    Stroke="#DDDDDD"
                    Padding="15,0">
                <Entry x:Name="EmailEntry"
                       Placeholder="Email"
                       PlaceholderColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}"
                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F5F5F5}"
                       Keyboard="Email"
                       BackgroundColor="Transparent"/>
            </Border>

            <Border StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    BackgroundColor="White"
                    Stroke="#DDDDDD"
                    Padding="15,0">
                <Entry x:Name="PasswordEntry"
                       Placeholder="Password"
                       PlaceholderColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}"
                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F5F5F5}"
                       IsPassword="True"
                       BackgroundColor="Transparent"/>
            </Border>

            <Border StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    BackgroundColor="White"
                    Stroke="#DDDDDD"
                    Padding="15,0">
                <Entry x:Name="ConfirmPasswordEntry"
                       Placeholder="Confirm Password"
                       PlaceholderColor="{AppThemeBinding Light=#AAAAAA, Dark=#666666}"
                       TextColor="{AppThemeBinding Light=#2D2D2D, Dark=#F5F5F5}"
                       IsPassword="True"
                       BackgroundColor="Transparent"/>
            </Border>

            <Label x:Name="ErrorLabel"
                   TextColor="Red"
                   HorizontalOptions="Center"
                   IsVisible="False"/>

            <Button Text="Register"
                    Clicked="OnRegisterClicked"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="10"
                    HeightRequest="50"
                    Margin="0,10,0,0"/>

            <Label HorizontalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLoginTapped"/>
                </Label.GestureRecognizers>
                <Label.FormattedText>
                    <FormattedString>
                        <Span Text="Already have an account? "
                              TextColor="{AppThemeBinding Light=#888888, Dark=#AAAAAA}"/>
                        <Span Text="Log In"
                              TextColor="#4CAF50"
                              FontAttributes="Bold"/>
                    </FormattedString>
                </Label.FormattedText>
            </Label>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>